{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Geti",
    "version": "0.1.0",
    "identifier": "com.intel",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "npm run start:tauri",
        "beforeBuildCommand": "npm run build:tauri"
    },
    "app": {
        "windows": [
            {
                "title": "Geti",
                "width": 1280,
                "height": 800,
                "resizable": true,
                "fullscreen": false,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "externalBin": ["geti-backend"],
        "resources": ["_internal"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico",
            "icons/icon.png"
        ]
    }
}
