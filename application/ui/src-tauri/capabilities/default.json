{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "dialog:allow-save",
        {
            "identifier": "fs:allow-write-file",
            "allow": [{ "path": "$HOME/**" }]
        },
        {
            "identifier": "opener:allow-open-url",
            "allow": [{ "url": "https://www.intel.com/*" }, { "url": "https://github.com/*" }]
        }
    ]
}
