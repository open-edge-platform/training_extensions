# Web dev uses same-origin requests (empty base URL) that the rsbuild dev
# server proxies to the backend (see `server.proxy` in rsbuild.config.ts).
# This mirrors production (UI served same-origin behind a reverse proxy) and
# avoids cross-origin CORS failures when the app is opened via 127.0.0.1 or a
# LAN IP instead of localhost. Tauri dev still targets http://localhost:7860
# directly via the fallback in rsbuild.config.ts.
PUBLIC_API_BASE_URL=