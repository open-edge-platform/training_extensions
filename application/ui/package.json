{
    "name": "@geti/app-ui",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=v24.2.0",
        "npm": ">=11.3.0"
    },
    "scripts": {
        "build": "rsbuild build",
        "build:api": "npx openapi-typescript ./src/api/openapi-spec.json -o ./src/api/openapi-spec.d.ts  --root-types && prettier --write src/api/openapi-spec.d.ts",
        "build:api:download": "curl -o ./src/api/openapi-spec.json http://localhost:7860/api/openapi.json && prettier --write src/api/openapi-spec.json",
        "update-spec": "npm run build:api:download && npm run build:api",
        "clone-geti-ui-packages": "npx tiged --force --mode=git https://github.com/open-edge-platform/geti.git/web_ui/packages/config#5f2032c6b2ef28a82721443e3725b11f70c7a89b packages/config && npx tiged --force --mode=git https://github.com/open-edge-platform/geti.git/web_ui/packages/ui#5f2032c6b2ef28a82721443e3725b11f70c7a89b packages/ui && npx tiged --force --mode=git https://github.com/open-edge-platform/geti.git/web_ui/packages/smart-tools#5f2032c6b2ef28a82721443e3725b11f70c7a89b packages/smart-tools",
        "cyclic-deps-check": "npx madge --circular src/**/*.ts*",
        "start": "rsbuild dev",
        "start:desktop": "tauri dev",
        "server": "uv --directory ../ run fastapi run --port 7860",
        "format": "prettier --write .",
        "format:check": "prettier --check --cache \"./src/**/*.{js,ts,jsx,tsx,css,scss,sass}\"",
        "lint": "eslint \"src/**/*.ts*\" --max-warnings 0",
        "lint:fix": "eslint --fix \"./src/**/*.ts*\"",
        "preinstall": "npm run clone-geti-ui-packages",
        "preview": "rsbuild preview",
        "test:unit": "vitest --config vitest.config.ts",
        "test:unit:watch": "vitest --config vitest.config.ts --reporter=verbose --watch",
        "test:unit:coverage": "vitest --coverage",
        "test:component": "npx playwright test --project=component",
        "test:e2e": "ENABLE_BACKEND=True npx playwright test --project=e2e",
        "type-check": "tsc --noEmit",
        "tauri": "tauri"
    },
    "dependencies": {
        "@geti/config": "*",
        "@geti/smart-tools": "*",
        "@geti/ui": "*",
        "@tanstack/react-query": "~5.99.0",
        "@use-gesture/react": "~10.3.1",
        "clsx": "~2.1.1",
        "comlink": "~4.4.2",
        "dayjs": "^1.11.20",
        "lodash-es": "~4.18.1",
        "openapi-fetch": "~0.16.0",
        "openapi-react-query": "0.5.3",
        "pretty-bytes": "^7.1.0",
        "react": "~19.2.5",
        "react-aria-components": "^1.17.0",
        "react-cool-virtual": "^0.7.0",
        "react-dom": "~19.2.5",
        "react-error-boundary": "~3.1.4",
        "react-hotkeys-hook": "^5.2.4",
        "react-router": "~6.30.3",
        "react-router-dom": "~6.30.3",
        "recharts": "~3.8.1",
        "static-path": "~0.0.4",
        "utif": "^3.1.0",
        "uuid": "~11.1.0"
    },
    "devDependencies": {
        "@eslint/compat": "~1.4.1",
        "@eslint/js": "~9.39.4",
        "@ianvs/prettier-plugin-sort-imports": "~4.7.1",
        "@msw/playwright": "~0.6.7",
        "@mswjs/source": "~0.4.1",
        "@playwright/test": "~1.59.1",
        "@rsbuild/core": "~1.7.5",
        "@rsbuild/plugin-babel": "~1.1.2",
        "@rsbuild/plugin-react": "~1.4.6",
        "@rsbuild/plugin-sass": "~1.5.1",
        "@rsbuild/plugin-svgr": "~1.3.1",
        "@tanstack/eslint-plugin-query": "~5.99.0",
        "@tauri-apps/cli": "~2.10.1",
        "@testing-library/jest-dom": "~6.9.1",
        "@testing-library/react": "~16.3.2",
        "@testing-library/user-event": "~14.6.1",
        "@types/lodash-es": "~4.17.12",
        "@types/node": "~24.12.2",
        "@types/react": "~19.2.14",
        "@types/react-dom": "~19.2.3",
        "@types/utif": "^3.0.6",
        "@types/uuid": "~10.0.0",
        "@typescript-eslint/eslint-plugin": "~8.58.2",
        "@vitejs/plugin-react": "~4.7.0",
        "@vitest/coverage-v8": "~3.2.4",
        "@wessberg/pointer-events": "^1.0.9",
        "babel-plugin-react-compiler": "~19.1.0-rc.3",
        "babel-preset-react-app": "~10.1.0",
        "baseline-browser-mapping": "^2.10.19",
        "eslint": "~9.39.4",
        "eslint-import-resolver-typescript": "~4.4.4",
        "eslint-plugin-header": "~3.1.1",
        "eslint-plugin-import": "~2.32.0",
        "eslint-plugin-jsx-a11y": "~6.10.2",
        "eslint-plugin-playwright": "~2.10.1",
        "eslint-plugin-react": "~7.37.5",
        "eslint-plugin-react-compiler": "~19.1.0-rc.2",
        "eslint-plugin-react-hooks": "~6.1.1",
        "identity-obj-proxy": "~3.0.0",
        "jsdom": "~26.1.0",
        "msw": "~2.13.3",
        "node-fetch": "~3.3.2",
        "openapi-msw": "~1.3.0",
        "openapi-typescript": "~7.13.0",
        "prettier": "~3.8.3",
        "typescript": "~5.9.3",
        "typescript-eslint": "~8.58.2",
        "vite": "~7.3.2",
        "vite-plugin-svgr": "~4.5.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "~3.2.4"
    },
    "workspaces": [
        "packages/*"
    ]
}
