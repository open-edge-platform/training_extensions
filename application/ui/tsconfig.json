{
    "extends": "@geti/config/typescript",
    "include": ["src", "tests", "rsbuild.config.ts", "vitest.config.ts", "playwright.config.ts", "mocks/mock-project.ts", "mocks/mock-projects.ts"],
    "compilerOptions": {
        "types": ["vitest/globals"],
