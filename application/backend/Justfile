#!/usr/bin/env just --justfile
import "../recipes.justfile"

app-main := "app/main.py"

default:
    @just --list --unsorted

# -------------------------------------------------------------------------------------------------
# Virtual environment management
# -------------------------------------------------------------------------------------------------

# Create a virtual environment and install dependencies
[arg("accelerator", short="a", long="accelerator")]
venv accelerator="cpu": install-uv
    uv lock --check
    uv sync --frozen --extra {{ accelerator }} --extra mqtt

# Generate or update the uv lock file
venv-lock: install-uv
    uv lock

# -------------------------------------------------------------------------------------------------
# Linting and formatting
# -------------------------------------------------------------------------------------------------

# Run linters (ruff + lint-imports + pyrefly)
lint: ruff lint-imports pyrefly

# Run ruff for linting and format checking
ruff: install-uv
    uv run ruff check --output-format=github
    uv run ruff format --check

# Run ruff to format the code and apply fixes
ruff-fix: install-uv
    uv run ruff check --fix
    uv run ruff format

# Run lint-imports for checking import statements
lint-imports: install-uv
    uv run lint-imports

# Run pyrefly to detect potential type errors
pyrefly: install-uv
    uv run pyrefly check

# -------------------------------------------------------------------------------------------------
# Testing
# -------------------------------------------------------------------------------------------------

# Run unit tests with pytest
test-unit *ARGS: install-uv
    uv run pytest ./tests/unit -v {{ ARGS }}

# Run integration tests with pytest
test-integration *ARGS: install-uv
    uv run pytest ./tests/integration -v {{ ARGS }}

# Run BDD tests with behave
test-bdd *ARGS: install-uv
    uv run behave ./tests/bdd -v {{ ARGS }}

# -------------------------------------------------------------------------------------------------
# Documentation
# -------------------------------------------------------------------------------------------------

# Generate OpenAPI specification from FastAPI app
[arg("output-path", short="o", long="output-path")]
gen-api-spec output-path="openapi.json": install-uv
    PYTHONPATH=. uv run --no-sync app/cli.py gen-api --target-path {{ output-path }}

# -------------------------------------------------------------------------------------------------
# Packaging
# -------------------------------------------------------------------------------------------------

# Repair malformed Mach-O dylibs shipped by some wheels (e.g. openvino) so
# that PyInstaller's ad-hoc codesigning step doesn't fail with
# "internal error in Code Signing subsystem". No-op on non-macOS.
fix-macho-signatures:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ "$(uname)" != "Darwin" ]]; then exit 0; fi
    python3 pyinstaller/fix_macho_signatures.py \
        .venv/lib/python*/site-packages/openvino \
        "$HOME/Library/Application Support/pyinstaller"

# Build a standalone executable using PyInstaller
[arg("accelerator", short="a", long="accelerator")]
pyinstaller accelerator="cpu": install-uv
    uv sync --frozen --extra {{accelerator}} --extra mqtt --extra installer
    just fix-macho-signatures
    uv run pyinstaller --noconfirm geti.spec

# -------------------------------------------------------------------------------------------------
# Development server
# -------------------------------------------------------------------------------------------------

# Clean all existing data and reset the database
[confirm("WARNING: This will delete all existing data and reset the database! Continue? (yes/no)")]
_clean_data: install-uv
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Cleaning existing data..."
    rm -f data/geti.db
    rm -rf data/projects/*
    rm -rf data/output/*
    uv run app/cli.py init-db
    echo "Database cleaned and reinitialized."

# Download and import demo projects, sources, and sinks
_setup_demo force_import="": install-uv
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Setting up demo projects..."
    FORCE_FLAG="{{ force_import }}"
    just import-demo-projects "$FORCE_FLAG"
    just setup-demo-sources
    just setup-demo-sinks
    echo "Demo setup complete."

# Run coturn server
[arg("coturn-host", long="coturn-host", help="Coturn server listening host (default: server's public IP)")]
[arg("coturn-port", long="coturn-port", help="Coturn server listening port (default: 443)")]
[arg("coturn-image", long="coturn-image", help="Coturn server Docker image to use (default: quay.io/coturn/coturn)")]
run-coturn coturn-host="" coturn-port="443" coturn-image="quay.io/coturn/coturn": install-uv
    #!/usr/bin/env bash
    set -euo pipefail

    EXTERNAL_IP=""
    if [[ -n "{{ coturn-host }}" ]]; then
        EXTERNAL_IP="{{ coturn-host }}"
    else
        EXTERNAL_IP=`uv run python -c "import socket; s=socket.socket(socket.AF_INET,socket.SOCK_DGRAM); s.connect(('8.8.8.8',80)); print(s.getsockname()[0]); s.close()"`
    fi
    echo "Running coturn server on port {{ coturn-port }} with external IP $EXTERNAL_IP..."

    docker run --rm --detach \
        --network=host \
        --name coturn-server \
        {{ coturn-image }} \
        -n \
        --listening-port={{ coturn-port }} \
        --external-ip=$EXTERNAL_IP \
        --user=user:password \
        --realm=my-realm \
        --no-udp \
        --log-file=stdout \
        --verbose

# Stop coturn server
stop-coturn:
    @echo "Stopping coturn server..."
    @docker stop coturn-server || true

# Run the application server as standalone (for development and testing)
[arg("host", long="host", help="Host address to bind the server to")]
[arg("port", long="port", help="Port number to bind the server to")]
[arg("webrtc_advertise_ip", long="webrtc-advertise-ip", help="Public IP address to advertise for WebRTC connections")]
[arg("log_level", long="log-level", help="Log level (e.g. DEBUG, INFO, WARNING, ERROR)")]
[arg("log_dir", long="log-dir", help="Directory for log files")]
[arg("data_dir", long="data-dir", help="Directory for application data")]
[arg("no_proxy", long="no-proxy", help="Comma-separated list of hosts to bypass proxy")]
[arg("clean", long="clean", value="true", help="Delete all existing data and reset the database before starting")]
[arg("setup_demo", long="setup-demo", value="true", help="Import demo projects, videos, and sinks before starting")]
[arg("force_import", long="force-import", value="true", help="Bypass schema version checks during import (requires --setup-demo)")]
[arg("enable_coturn", long="coturn", help="Enable coturn server for WebRTC relay (only needed if the server is behind a restrictive NAT)")]
[arg("coturn_host", long="coturn-host", help="Coturn server listening host (default: server's public IP)")]
[arg("coturn_port", long="coturn-port", help="Coturn server listening port (default: 443)")]
[arg("coturn_image", long="coturn-image", help="Coturn server Docker image to use (default: quay.io/coturn/coturn)")]
[arg("stun_server", long="stun", help="STUN server URL to use for WebRTC")]
run-server clean="" setup_demo="" force_import="" host="" port="" webrtc_advertise_ip="" log_level="" log_dir="" data_dir="" no_proxy="" enable_coturn="false" coturn_host="" coturn_port="443" coturn_image="quay.io/coturn/coturn" stun_server="": install-uv
    #!/usr/bin/env bash
    set -euo pipefail
    export PYTHONUNBUFFERED=1
    export PYTHONPATH=.

    # Validate arguments
    if [[ "{{ force_import }}" == "true" && "{{ setup_demo }}" != "true" ]]; then
        echo "Error: --force-import can only be used with --setup-demo" >&2
        exit 1
    fi

    # Handle data cleanup
    if [[ "{{ clean }}" == "true" ]]; then
        just _clean_data
    fi

    # Handle demo setup
    if [[ "{{ setup_demo }}" == "true" ]]; then
        FORCE_FLAG=""
        if [[ "{{ force_import }}" == "true" ]]; then
            FORCE_FLAG="--force-import"
        fi
        just _setup_demo "${FORCE_FLAG}"
    fi

    # Export optional settings as environment variables
    if [[ -n "{{ host }}" ]]; then
        export HOST="{{ host }}"
    fi
    if [[ -n "{{ port }}" ]]; then
        export PORT="{{ port }}"
    fi
    if [[ -n "{{ webrtc_advertise_ip }}" ]]; then
        export WEBRTC_ADVERTISE_IP="{{ webrtc_advertise_ip }}"
    fi
    if [[ -n "{{ log_level }}" ]]; then
        export LOG_LEVEL="{{ log_level }}"
    fi
    if [[ -n "{{ log_dir }}" ]]; then
        export LOG_DIR="{{ log_dir }}"
    fi
    if [[ -n "{{ data_dir }}" ]]; then
        export DATA_DIR="{{ data_dir }}"
    fi
    if [[ -n "{{ no_proxy }}" ]]; then
        export no_proxy="{{ no_proxy }}"
    fi

    if [[ "{{ enable_coturn }}" == "true" ]]; then
        export COTURN_PORT="{{ coturn_port }}"
        if [[ -n "{{ coturn_host }}" ]]; then
            export COTURN_HOST="{{ coturn_host }}"
        else
            export COTURN_HOST=`uv run python -c "import socket; s=socket.socket(socket.AF_INET,socket.SOCK_DGRAM); s.connect(('8.8.8.8',80)); print(s.getsockname()[0]); s.close()"`
        fi
        just run-coturn --coturn-host $COTURN_HOST --coturn-port {{ coturn_port }} --coturn-image {{ coturn_image }}
    fi
    if [[ -n "{{ stun_server }}" ]]; then
        export STUN_SERVER="{{ stun_server }}"
    fi

    echo "Starting FastAPI server..."
    trap 'kill $(jobs -p) 2>/dev/null || true; {{ if enable_coturn == "true" { "just stop-coturn" } else { "" } }}' EXIT
    uv run {{ app-main }}
